{
  "name": "canopycms-cdk",
  "version": "0.0.22",
  "description": "AWS CDK constructs and EC2 worker for CanopyCMS deployment",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/safeinsights/canopycms.git",
    "directory": "packages/canopycms-cdk"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "worker/dist",
    "worker/canopy-worker.service"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "build:worker": "esbuild worker/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=worker/dist/index.js --external:@aws-sdk/*",
    "lint": "eslint src/",
    "test": "echo \"No tests yet\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.150.0",
    "constructs": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "aws-cdk-lib": {
      "optional": true
    },
    "constructs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "aws-cdk-lib": "^2.150.0",
    "canopycms": "workspace:*",
    "canopycms-auth-clerk": "workspace:*",
    "@octokit/rest": "^20.0.2",
    "simple-git": "^3.22.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "constructs": "^10.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
