{
  "name": "canopycms-next",
  "version": "0.0.33",
  "description": "Next.js adapter for CanopyCMS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/safeinsights/canopycms.git",
    "directory": "packages/canopycms-next"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.tsx",
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.cjs",
      "import": "./dist/config.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "require": "./dist/config.cjs",
        "import": "./dist/config.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && esbuild src/config.ts --bundle --platform=node --packages=external --external:next --format=cjs --outfile=dist/config.cjs && esbuild src/config.ts --bundle --platform=node --packages=external --external:next --format=esm --outfile=dist/config.mjs",
    "lint": "eslint src/",
    "test": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "canopycms": "workspace:*",
    "next": "^13.5.7 || ^14.2.25 || ^15.2.3 || ^16",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.2",
    "@types/react": "^18.3.12",
    "canopycms": "workspace:*",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
