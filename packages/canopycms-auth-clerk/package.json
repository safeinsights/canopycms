{
  "name": "canopycms-auth-clerk",
  "version": "0.0.5",
  "description": "Clerk authentication provider for CanopyCMS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/safeinsights/canopycms.git",
    "directory": "packages/canopycms-auth-clerk"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./cache-writer": "./src/cache-writer.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./client": {
        "import": "./dist/client.js",
        "types": "./dist/client.d.ts"
      },
      "./cache-writer": {
        "import": "./dist/cache-writer.js",
        "types": "./dist/cache-writer.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/",
    "test": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "canopycms": "workspace:^",
    "@clerk/backend": "^2.0.0",
    "@clerk/nextjs": "^6.0.0"
  },
  "devDependencies": {
    "@clerk/backend": "^2.0.0",
    "@clerk/nextjs": "^6.0.0",
    "@types/node": "^22.9.0",
    "canopycms": "workspace:*",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0"
  }
}
