{
  "name": "canopycms",
  "version": "0.0.3",
  "description": "CanopyCMS core package: schema-driven content, branch-aware editing, and editor UI for Next.js.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/safeinsights/canopycms.git",
    "directory": "packages/canopycms"
  },
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "canopycms": "./src/cli/init.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/cache": "./src/auth/cache.ts",
    "./http": "./src/http/index.ts",
    "./task-queue": "./src/task-queue/index.ts",
    "./worker/task-queue": "./src/worker/task-queue.ts",
    "./worker/cms-worker": "./src/worker/cms-worker.ts",
    "./ai": "./src/ai/index.ts",
    "./build": "./src/build/index.ts"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./client": {
        "import": "./dist/client.js",
        "types": "./dist/client.d.ts"
      },
      "./server": {
        "import": "./dist/server.js",
        "types": "./dist/server.d.ts"
      },
      "./auth": {
        "import": "./dist/auth/index.js",
        "types": "./dist/auth/index.d.ts"
      },
      "./auth/cache": {
        "import": "./dist/auth/cache.js",
        "types": "./dist/auth/cache.d.ts"
      },
      "./http": {
        "import": "./dist/http/index.js",
        "types": "./dist/http/index.d.ts"
      },
      "./task-queue": {
        "import": "./dist/task-queue/index.js",
        "types": "./dist/task-queue/index.d.ts"
      },
      "./worker/task-queue": {
        "import": "./dist/worker/task-queue.js",
        "types": "./dist/worker/task-queue.d.ts"
      },
      "./worker/cms-worker": {
        "import": "./dist/worker/cms-worker.js",
        "types": "./dist/worker/cms-worker.d.ts"
      },
      "./ai": {
        "import": "./dist/ai/index.js",
        "types": "./dist/ai/index.d.ts"
      },
      "./build": {
        "import": "./dist/build/index.js",
        "types": "./dist/build/index.d.ts"
      }
    },
    "bin": {
      "canopycms": "./dist/cli/init.js"
    }
  },
  "scripts": {
    "prebuild": "npx tsx scripts/generate-client.ts",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node scripts/postbuild.mjs",
    "lint": "eslint src/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:client": "npx tsx scripts/generate-client.ts",
    "storybook": "storybook dev -p 6006 -c .storybook",
    "storybook:build": "storybook build -c .storybook"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.13.3",
    "@mantine/colors-generator": "^7.14.2",
    "@mantine/core": "^7.14.2",
    "@mantine/hooks": "^7.14.2",
    "@mantine/modals": "^7.14.2",
    "@mantine/notifications": "^7.14.2",
    "@mdxeditor/editor": "^3.52.4",
    "@octokit/rest": "^20.0.2",
    "chokidar": "^4.0.3",
    "chroma-js": "^3.2.0",
    "gray-matter": "^4.0.3",
    "minimatch": "^9.0.5",
    "pathe": "^1.1.2",
    "react-icons": "^5.5.0",
    "react-split-pane": "^0.1.92",
    "short-uuid": "^6.0.3",
    "simple-git": "^3.22.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@storybook/addon-essentials": "^8.1.11",
    "@storybook/react": "^8.1.11",
    "@storybook/react-vite": "^8.1.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.47",
    "storybook": "^8.6.14",
    "tsx": "^4.19.0"
  }
}
